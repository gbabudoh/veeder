# Application environment: local | test | staging | production
# Drives HTTPS enforcement (off for local/test, on for staging/production).
APP_ENV=local

# HTTP port the server binds to.
PORT=3000

# PostgreSQL connection string used by pg/knex.
# Local example:
#   postgres://postgres:postgres@localhost:5432/veeder
# Remote VPS example (note the DB name and credentials you created on the VPS):
#   postgres://veeder_user:STRONG_PASSWORD@your-vps-host-or-ip:5432/veeder
DATABASE_URL=postgres://postgres:LetMeGetaces232823@109.205.181.195:5432/veeder

# SSL for the database connection.
# Remote/VPS PostgreSQL usually requires TLS — set this to "require" in
# staging/production. Leave unset (or "disable") for a local database.
#   require  -> connect over SSL
#   disable  -> plain connection (default)
DB_SSL=disable
# When DB_SSL=require and the server uses a self-signed certificate, set this to
# "false" to skip certificate verification. Leave "true" when the DB presents a
# CA-signed cert.
DB_SSL_REJECT_UNAUTHORIZED=true

# Secret used to sign JWT access tokens (HS256).
# MUST be at least 32 characters; startup aborts if missing or shorter.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SIGNING_KEY=KFl97iVqBH6GxwF//TteEkxzYEVhqIv3Ljn8mzXYwOE=

# Number of trusted proxy hops in front of the service (load balancer / TLS
# terminator). Used to derive the real client IP for rate limiting and audit
# logging. Set to the number of proxies (e.g. 1 behind nginx) in production;
# defaults to 0 (disabled) locally.
TRUST_PROXY_HOPS=0

# Optional: separate database for the automated test suite (used when APP_ENV=test).
# DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/veeder_test
